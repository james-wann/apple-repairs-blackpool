---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import { SITE_INFO } from '../data/site.ts';

const title = `Mac Mini Repair | ${SITE_INFO.name}`;
const description = `Mac Mini repair in Blackpool. Common faults diagnosed and repaired by a certified Apple technician. Genuine parts, 90 day warranty.`;
---

<Base title={title} description={description}>

  <PageHero
    eyebrow="Mac Mini"
    title="Repairs to the Mac Mini."
    lead="Diagnostic, repair and upgrade for every Mac Mini generation."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get a quote', variant: 'secondary' }
    ]}
  />

  <section class="content-section">
    <div class="container">
      <h2 class="display-2">Common Mac Mini repairs.</h2>
      <p>Mac Mini machines are compact, well-engineered, and very serviceable when something goes wrong. We diagnose faults across the full range, from the early Intel-based models to the current Apple silicon M-series.</p>

      <ServiceGrid category="mac-mini" />
    </div>
  </section>

  <CtaBand
    title="Need a Mac Mini sorted?"
    lead="Drop it in or arrange an onsite visit. Most jobs back within 24 to 48 hours."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get in touch', variant: 'secondary' }
    ]}
  />

</Base>
