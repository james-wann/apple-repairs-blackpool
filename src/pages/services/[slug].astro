---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { SITE_INFO } from '../../data/site.ts';

export async function getStaticPaths() {
  const services = await getCollection('services');
  // Only services flagged standalone get their own page. Keeps thin content out of the index.
  return services
    .filter((s: CollectionEntry<'services'>) => s.data.standalone)
    .map((s: CollectionEntry<'services'>) => ({
      params: { slug: s.slug },
      props: { service: s }
    }));
}

const { service } = Astro.props;
const { Content } = await service.render();

const title = `${service.data.title} | ${SITE_INFO.name}`;
const description = service.data.description;

// Service schema — Google's preferred structured data for service offerings.
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.data.title,
  description: service.data.description,
  provider: {
    '@type': 'LocalBusiness',
    '@id': `${SITE_INFO.url}/#business`
  },
  areaServed: SITE_INFO.serviceAreas.map(area => ({ '@type': 'City', name: area.name })),
  ...(service.data.priceFrom && {
    offers: {
      '@type': 'Offer',
      priceCurrency: 'GBP',
      price: service.data.priceFrom.replace(/[^0-9]/g, ''),
      priceSpecification: {
        '@type': 'PriceSpecification',
        priceCurrency: 'GBP',
        minPrice: service.data.priceFrom.replace(/[^0-9]/g, '')
      }
    }
  })
};
---

<Base title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />

  <PageHero
    eyebrow={`Service${service.data.priceFrom ? ` · From ${service.data.priceFrom}` : ''}`}
    title={service.data.title}
    lead={service.data.description}
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get a quote', variant: 'secondary' }
    ]}
  />

  <section class="content-section">
    <div class="container">
      <Content />
    </div>
  </section>

  <CtaBand
    title="Ready to book this in?"
    lead="Workshop drop-off or onsite visit. Diagnostic £75, deducted from any repair. 90 day warranty."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get in touch', variant: 'secondary' }
    ]}
  />
</Base>
