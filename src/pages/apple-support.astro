---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import { SITE_INFO } from '../data/site.ts';

const title = `Apple Support & Onsite Engineer | ${SITE_INFO.name}`;
const description = `Onsite and home Apple support across the Fylde Coast. Experienced Apple technician for macOS, email, storage, and business setups. Call ${SITE_INFO.phone.landline.display}.`;
---

<Base title={title} description={description}>

  <PageHero
    eyebrow="Support"
    title="Onsite Apple support across the Fylde."
    lead="We come to your home or business. macOS help, email setup, drive issues, business networks, the lot."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get in touch', variant: 'secondary' }
    ]}
  />

  <section class="content-section">
    <div class="container">
      <h2 class="display-2">Onsite engineer visits.</h2>
      <p>Some jobs are easier done at your location than at the workshop. Office Mac setups, home networks, multi-Mac migrations, email troubles, drive issues that need to be diagnosed where the kit lives.</p>

      <ServiceGrid category="support" />
    </div>
  </section>

  <CtaBand
    title="Need an Apple engineer onsite?"
    lead="Call to arrange. We cover Blackpool, Cleveleys, Lytham, Fleetwood, Poulton, Kirkham, Preston, Lancaster, Morecambe and Blackburn."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get in touch', variant: 'secondary' }
    ]}
  />

</Base>
