---
import Base from '../layouts/Base.astro';

const title = 'Contact Apple Repairs Blackpool';
const description = 'Get in touch with Apple Repairs Blackpool. Phone 01253 445032 or 07873 170729. Independent Apple specialists serving the Fylde Coast and Lancashire.';
---

<Base title={title} description={description}>

  <section class="page-hero mesh-bg">
    <div class="container">
      <span class="glass-pill" style="margin-bottom: 24px;">Contact</span>
      <h1 class="display-1">Get in touch.</h1>
      <p class="lead">Phone, email, or send the form below. We aim to respond within 24 hours.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start;">

        <div>
          <h2 class="display-3" style="margin-bottom: 18px;">Apple Repairs Blackpool</h2>
          <p style="margin-bottom: 24px;">Independent Apple specialists serving Blackpool, Cleveleys, Lytham, Fleetwood, Poulton, Kirkham, Preston, Lancaster, Morecambe and Blackburn.</p>

          <h3 style="margin-top: 0;">Phone</h3>
          <p>
            <a href="tel:01253445032" style="font-size: 19px; font-weight: 600;">01253 445032</a><br />
            <a href="tel:07873170729" style="font-size: 19px; font-weight: 600;">07873 170729</a>
          </p>

          <h3>Email</h3>
          <p><a href="mailto:contact@applerepairsblackpool.co.uk">contact@applerepairsblackpool.co.uk</a></p>

          <h3>Studio</h3>
          <p>Cleveleys, FY5 1RY<br />Lancashire, United Kingdom</p>

          <h3>Hours</h3>
          <p>Monday to Friday: 9am to 5pm<br />Saturday: by appointment<br />Sunday: closed</p>

          <h3>Diagnostic fee</h3>
          <p>£75 diagnostic if we can't tell you what's wrong over the phone. Deducted from any repair cost.</p>
        </div>

        <div>
          <h2 class="display-3" style="margin-bottom: 18px;">Send a message.</h2>
          <p>The fastest way to get a quote. We'll come back to you within 24 hours.</p>

          <!-- Netlify Forms: data-netlify="true" + hidden form-name tells Netlify to capture submissions. -->
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="contact-form"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p style="display: none;">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div>
              <label for="name">Name</label>
              <input id="name" name="name" type="text" required />
            </div>

            <div>
              <label for="email">Email</label>
              <input id="email" name="email" type="email" required />
            </div>

            <div>
              <label for="phone">Phone (optional)</label>
              <input id="phone" name="phone" type="tel" />
            </div>

            <div>
              <label for="message">How can we help?</label>
              <textarea id="message" name="message" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Send message</button>
          </form>
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  @media (max-width: 880px) {
    .content-section div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
    }
  }
</style>
