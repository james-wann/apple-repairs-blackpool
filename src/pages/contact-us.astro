---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { SITE_INFO } from '../data/site.ts';

const title = `Contact ${SITE_INFO.name}`;
const description = `Get in touch with ${SITE_INFO.name}. Phone ${SITE_INFO.phone.landline.display} or ${SITE_INFO.phone.mobile.display}. Independent Apple specialists serving the Fylde Coast and Lancashire.`;

const areaNames = SITE_INFO.serviceAreas.map(a => a.name).join(', ');
---

<Base title={title} description={description}>

  <PageHero
    eyebrow="Contact"
    title="Get in touch."
    lead="Phone, email, or send the form below. We aim to respond within 24 hours."
  />

  <section class="content-section">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start;">

        <div>
          <h2 class="display-3" style="margin-bottom: 18px;">{SITE_INFO.name}</h2>
          <p style="margin-bottom: 24px;">Independent Apple specialists serving {areaNames}.</p>

          <h3 style="margin-top: 0;">Phone</h3>
          <p>
            <a href={SITE_INFO.phone.landline.href} style="font-size: 19px; font-weight: 600;">{SITE_INFO.phone.landline.display}</a><br />
            <a href={SITE_INFO.phone.mobile.href} style="font-size: 19px; font-weight: 600;">{SITE_INFO.phone.mobile.display}</a>
          </p>

          <h3>Email</h3>
          <p><a href={`mailto:${SITE_INFO.email}`}>{SITE_INFO.email}</a></p>

          <h3>Studio</h3>
          <p>{SITE_INFO.address.locality}, {SITE_INFO.address.postcode}<br />{SITE_INFO.address.region}, United Kingdom</p>

          <h3>Hours</h3>
          <p>Monday to Friday: {SITE_INFO.hours.weekday}<br />Saturday: {SITE_INFO.hours.saturday}<br />Sunday: {SITE_INFO.hours.sunday}</p>

          <h3>Diagnostic fee</h3>
          <p>{SITE_INFO.diagnosticFee} diagnostic if we can't tell you what's wrong over the phone. Deducted from any repair cost.</p>
        </div>

        <div>
          <h2 class="display-3" style="margin-bottom: 18px;">Send a message.</h2>
          <p>The fastest way to get a quote. We'll come back to you within 24 hours.</p>

          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="contact-form"
          >
            <input type="hidden" name="form-name" value="contact" />
            <p style="display: none;">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div>
              <label for="name">Name</label>
              <input id="name" name="name" type="text" required />
            </div>

            <div>
              <label for="email">Email</label>
              <input id="email" name="email" type="email" required />
            </div>

            <div>
              <label for="phone">Phone (optional)</label>
              <input id="phone" name="phone" type="tel" />
            </div>

            <div>
              <label for="message">How can we help?</label>
              <textarea id="message" name="message" required></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Send message</button>
          </form>
        </div>

      </div>
    </div>
  </section>

</Base>

<style>
  @media (max-width: 880px) {
    .content-section div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
      gap: 48px !important;
    }
  }
</style>
