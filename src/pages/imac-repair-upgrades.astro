---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import { SITE_INFO } from '../data/site.ts';

const title = `iMac Repair and Upgrades | ${SITE_INFO.name}`;
const description = `Out-of-warranty iMac repair in Blackpool. Screen replacement, HDD and SSD upgrades, GPU and PSU faults, liquid damage, RAM upgrades, data recovery, logic board reballing.`;
---

<Base title={title} description={description}>

  <PageHero
    eyebrow="iMac Repair and Upgrades"
    title="iMac repairs in Blackpool."
    lead="Out-of-warranty repair and upgrades, by a certified Apple technician."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get a quote', variant: 'secondary' }
    ]}
  />

  <section class="content-section">
    <div class="container">
      <h2 class="display-2">What we fix on iMacs.</h2>
      <p>From the classic Intel iMacs to the latest Apple silicon machines, we handle the full range of out-of-warranty repairs and upgrades. Every job uses OEM Apple parts where available, and comes with a 90 day warranty on parts and labour.</p>

      <ServiceGrid category="imac" />
    </div>
  </section>

  <CtaBand
    title="Got an iMac issue?"
    lead="Call or message us. Most repairs back with you in 24 to 48 hours."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get in touch', variant: 'secondary' }
    ]}
  />

</Base>
