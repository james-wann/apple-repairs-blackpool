---
import Base from '../layouts/Base.astro';

const title = 'iMac Repair and Upgrades | Apple Repairs Blackpool';
const description = 'Out-of-warranty iMac repair in Blackpool. Screen replacement, HDD and SSD upgrades, GPU and PSU faults, liquid damage, RAM upgrades, data recovery, logic board reballing.';
---

<Base title={title} description={description}>

  <section class="page-hero mesh-bg">
    <div class="container">
      <span class="glass-pill" style="margin-bottom: 24px;">iMac Repair and Upgrades</span>
      <h1 class="display-1">iMac repairs in Blackpool.</h1>
      <p class="lead">Out-of-warranty repair and upgrades, by a certified Apple technician.</p>
      <div class="ctas">
        <a href="tel:01253445032" class="btn btn-primary">Call 01253 445032</a>
        <a href="/contact-us/" class="btn btn-secondary">Get a quote</a>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <h2 class="display-2">What we fix on iMacs.</h2>
      <p>From the classic Intel iMacs to the latest Apple silicon machines, we handle the full range of out-of-warranty repairs and upgrades. Every job uses OEM Apple parts where available, and comes with a 90 day warranty on parts and labour.</p>

      <div class="service-grid">
        <div class="service-card">
          <h3>Screen replacement</h3>
          <p>Cracked, flickering or dead iMac displays. We handle both LCD and the newer Retina panels.</p>
        </div>
        <div class="service-card">
          <h3>HDD and SSD upgrades</h3>
          <p>Breathe new life into an older iMac with solid-state storage. Significantly faster boot, faster everything.</p>
        </div>
        <div class="service-card">
          <h3>GPU and PSU faults</h3>
          <p>Graphics card and power supply failures diagnosed and replaced where parts are available.</p>
        </div>
        <div class="service-card">
          <h3>Liquid damage</h3>
          <p>Diagnostic, ultrasonic clean and board-level repair where feasible. Honest assessment if it's beyond economical repair.</p>
        </div>
        <div class="service-card">
          <h3>RAM upgrades</h3>
          <p>Where the model supports it, doubling or quadrupling memory can transform performance.</p>
        </div>
        <div class="service-card">
          <h3>Data recovery</h3>
          <p>Failed drives, deleted files, water damage. Free assessment.</p>
        </div>
        <div class="service-card">
          <h3>Logic board reballing</h3>
          <p>Component-level board repair on older iMacs where graphics chip reflow or reballing can resolve common failure modes.</p>
        </div>
        <div class="service-card">
          <h3>Diagnostic</h3>
          <p>£75 diagnostic fee if you're unsure what's wrong. Deducted from the repair cost if you go ahead.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2 class="display-2">Got an iMac issue?</h2>
      <p class="lead">Call or message us. Most repairs back with you in 24 to 48 hours.</p>
      <div class="ctas">
        <a href="tel:01253445032" class="btn btn-primary">Call 01253 445032</a>
        <a href="/contact-us/" class="btn btn-secondary">Get in touch</a>
      </div>
    </div>
  </section>

</Base>
