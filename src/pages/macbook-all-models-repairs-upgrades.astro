---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import { SITE_INFO } from '../data/site.ts';

const title = `MacBook Repairs & Upgrades | All MacBook Models | ${SITE_INFO.name}`;
const description = `MacBook screen, keyboard, battery and fan replacement in Blackpool. All MacBook Air and MacBook Pro models. Certified Apple technician, OEM parts, 90 day warranty.`;
---

<Base title={title} description={description}>

  <PageHero
    eyebrow="MacBook Repairs &amp; Upgrades"
    title="MacBook repairs and upgrades. All models."
    lead="MacBook Air. MacBook Pro. Every generation, every fault."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get a quote', variant: 'secondary' }
    ]}
  />

  <section class="content-section">
    <div class="container">
      <h2 class="display-2">What we fix on MacBooks.</h2>
      <p>From classic Intel-era MacBook Pros through to current M-series MacBook Airs, we handle screen replacement, keyboard replacement, battery refresh, fan replacement, liquid damage recovery and storage upgrades where the model supports them.</p>

      <ServiceGrid category="macbook" />
    </div>
  </section>

  <CtaBand
    title="MacBook playing up?"
    lead="Most repairs back with you in 24 to 48 hours. Call to discuss."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get in touch', variant: 'secondary' }
    ]}
  />

</Base>
