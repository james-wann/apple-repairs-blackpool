---
import Base from '../layouts/Base.astro';

const title = 'MacBook Repairs & Upgrades | All MacBook Models | Apple Repairs Blackpool';
const description = 'MacBook screen, keyboard, battery and fan replacement in Blackpool. All MacBook Air and MacBook Pro models. Certified Apple technician, OEM parts, 90 day warranty.';
---

<Base title={title} description={description}>

  <section class="page-hero mesh-bg">
    <div class="container">
      <span class="glass-pill" style="margin-bottom: 24px;">MacBook Repairs &amp; Upgrades</span>
      <h1 class="display-1">MacBook repairs and upgrades. All models.</h1>
      <p class="lead">MacBook Air. MacBook Pro. Every generation, every fault.</p>
      <div class="ctas">
        <a href="tel:01253445032" class="btn btn-primary">Call 01253 445032</a>
        <a href="/contact-us/" class="btn btn-secondary">Get a quote</a>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <h2 class="display-2">What we fix on MacBooks.</h2>
      <p>From classic Intel-era MacBook Pros through to current M-series MacBook Airs, we handle screen replacement, keyboard replacement, battery refresh, fan replacement, liquid damage recovery and storage upgrades where the model supports them.</p>

      <div class="service-grid">
        <div class="service-card">
          <h3>Screen replacement</h3>
          <p>Cracked, flickering or dead MacBook displays. Both Air and Pro models, all sizes.</p>
        </div>
        <div class="service-card">
          <h3>Keyboard replacement</h3>
          <p>Sticky keys, unresponsive keys, full keyboard swap. We handle the older butterfly-keyboard era models too.</p>
        </div>
        <div class="service-card">
          <h3>Battery replacement</h3>
          <p>Genuine Apple battery cells. Restored full-day battery life on machines you thought were past it.</p>
        </div>
        <div class="service-card">
          <h3>Fan and cooling</h3>
          <p>Fan replacement, thermal paste refresh, internal clean. Often the cause of unexplained slowdowns and shutdowns.</p>
        </div>
        <div class="service-card">
          <h3>Liquid damage</h3>
          <p>Diagnostic, ultrasonic clean, board-level repair where feasible. Honest assessment of viability.</p>
        </div>
        <div class="service-card">
          <h3>Diagnostic</h3>
          <p>£75 diagnostic fee if you're unsure what's wrong. Deducted from the repair cost if you go ahead.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2 class="display-2">MacBook playing up?</h2>
      <p class="lead">Most repairs back with you in 24 to 48 hours. Call to discuss.</p>
      <div class="ctas">
        <a href="tel:01253445032" class="btn btn-primary">Call 01253 445032</a>
        <a href="/contact-us/" class="btn btn-secondary">Get in touch</a>
      </div>
    </div>
  </section>

</Base>
