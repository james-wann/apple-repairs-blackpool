---
import Base from '../layouts/Base.astro';

const title = 'Storage & Data Recovery | Apple Repairs Blackpool';
const description = 'Mac storage upgrades, HDD/SSD/hybrid replacement, data recovery and OS password removal in Blackpool. Certified Apple technician, 90 day warranty.';
---

<Base title={title} description={description}>

  <section class="page-hero mesh-bg">
    <div class="container">
      <span class="glass-pill" style="margin-bottom: 24px;">Storage</span>
      <h1 class="display-1">Storage upgrades, data recovery, password removal.</h1>
      <p class="lead">Faster drives, recovered files, locked Macs unlocked.</p>
      <div class="ctas">
        <a href="tel:01253445032" class="btn btn-primary">Call 01253 445032</a>
        <a href="/contact-us/" class="btn btn-secondary">Get a quote</a>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <h2 class="display-2">Storage and recovery services.</h2>
      <p>If your Mac is slow, full, failing, or locked, this is the page. We replace storage, recover data, and reset OS-level passwords on supported models.</p>

      <div class="service-grid">
        <div class="service-card">
          <h3>HDD replacement</h3>
          <p>Failed spinning drives swapped out. Where we can, we'll recover and migrate your data as part of the job.</p>
        </div>
        <div class="service-card">
          <h3>SSD upgrade</h3>
          <p>The single biggest performance lift for an older Mac. Solid-state storage with the capacity you actually need.</p>
        </div>
        <div class="service-card">
          <h3>Hybrid (Fusion) replacement</h3>
          <p>Apple's hybrid Fusion drives commonly fail at the SSD-cache half. We replace and reconfigure, or migrate to a pure SSD setup.</p>
        </div>
        <div class="service-card">
          <h3>Data recovery</h3>
          <p>Failed drives, deleted files, liquid damage. Free initial assessment. Honest about what's recoverable and what isn't.</p>
        </div>
        <div class="service-card">
          <h3>OS password removal</h3>
          <p>Inherited a locked Mac? Forgotten the admin password? We can reset on supported models, with proof of ownership.</p>
        </div>
        <div class="service-card">
          <h3>macOS reinstall</h3>
          <p>Clean install, migration, and verified backup. Ideal when buying a used Mac or passing one on.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2 class="display-2">Storage trouble?</h2>
      <p class="lead">Bring it in or call. We'll tell you what's recoverable before you commit.</p>
      <div class="ctas">
        <a href="tel:01253445032" class="btn btn-primary">Call 01253 445032</a>
        <a href="/contact-us/" class="btn btn-secondary">Get in touch</a>
      </div>
    </div>
  </section>

</Base>
