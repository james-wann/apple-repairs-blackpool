---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import { SITE_INFO } from '../data/site.ts';

const title = `Storage & Data Recovery | ${SITE_INFO.name}`;
const description = `Mac storage upgrades, HDD/SSD/hybrid replacement, data recovery and OS password removal in Blackpool. Experienced Apple technician, 90 day warranty.`;
---

<Base title={title} description={description}>

  <PageHero
    eyebrow="Storage"
    title="Storage upgrades, data recovery, password removal."
    lead="Faster drives, recovered files, locked Macs unlocked."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get a quote', variant: 'secondary' }
    ]}
  />

  <section class="content-section">
    <div class="container">
      <h2 class="display-2">Storage and recovery services.</h2>
      <p>If your Mac is slow, full, failing, or locked, this is the page. We replace storage, recover data, and reset OS-level passwords on supported models.</p>

      <ServiceGrid category="storage" />
    </div>
  </section>

  <CtaBand
    title="Storage trouble?"
    lead="Bring it in or call. We'll tell you what's recoverable before you commit."
    ctas={[
      { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
      { href: '/contact-us/', label: 'Get in touch', variant: 'secondary' }
    ]}
  />

</Base>
