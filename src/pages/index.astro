---
import Base from '../layouts/Base.astro';
import PillarTile from '../components/PillarTile.astro';
import { SITE_INFO } from '../data/site.ts';

const title = `${SITE_INFO.name} | Independent Apple Specialists with OEM Parts`;
const description = `Independent Apple specialists in Blackpool. Experienced Apple technicians, 100% genuine Apple parts, onsite repairs across the Fylde Coast. Call ${SITE_INFO.phone.landline.display}.`;
---

<Base title={title} description={description}>

  <!-- HERO — homepage-only treatment with product imagery -->
  <section class="page-hero mesh-bg">
    <div class="container">
      <span class="glass-pill" style="margin-bottom: 18px;"><span class="dot"></span> Apple Specialists. Open today.</span>
      <h1 class="display-xl">Apple Repairs.</h1>
      <p class="lead">Independent. Local. Experienced.</p>
      <p style="display: inline-flex; align-items: center; gap: 8px; margin-top: 8px; margin-bottom: 24px; font-size: 15px; color: var(--ink);">
        <span style="color: #f4a032; letter-spacing: 2px; font-size: 17px;">★★★★★</span>
        <strong>{SITE_INFO.reviews.rating.toFixed(1)}</strong>
        <span style="color: var(--ink-soft);">from {SITE_INFO.reviews.count} Google reviews</span>
      </p>
      <div class="ctas">
        <a href={SITE_INFO.phone.landline.href} class="btn btn-primary">Call {SITE_INFO.phone.landline.display}</a>
        <a href={SITE_INFO.phone.mobile.href} class="btn btn-secondary">Call {SITE_INFO.phone.mobile.display}</a>
      </div>
    </div>
    <div style="max-width: 1200px; margin: 64px auto 0; padding: 0 22px; position: relative; z-index: 2;">
      <div
        style="
          width: 100%;
          max-width: 980px;
          aspect-ratio: 16 / 10;
          margin: 0 auto;
          border-radius: 20px;
          background-image: linear-gradient(180deg, rgba(0,0,0,0) 60%, rgba(0,0,0,0.12) 100%), url('https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=1600&q=85&auto=format&fit=crop');
          background-size: cover;
          background-position: center;
          box-shadow: var(--shadow-lg);
        "
        role="img"
        aria-label="Mac on a desk"
      ></div>
    </div>
  </section>

  <!-- THREE PILLARS — PillarTile components -->
  <section class="section-light">
    <div class="grid-3">

      <PillarTile
        label="Apple Specialists"
        title="Qualified Apple Engineer."
        subtitle="We are Apple specialists."
        photoUrl="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=1200&q=85&auto=format&fit=crop"
        ctas={[
          { href: '/apple-support/', label: 'We Only Deal With Apple', variant: 'arrow' }
        ]}
      />

      <PillarTile
        label="OEM Parts"
        title="100% Genuine Apple Parts."
        subtitle="90 Days Warranty on Parts and Labour."
        photoUrl="https://images.unsplash.com/photo-1518770660439-4636190af475?w=1200&q=85&auto=format&fit=crop"
        variant="dark"
        ctas={[
          { href: '/apple-support/', label: 'Get Your Mac back between 24 and 48 hours', variant: 'arrow' }
        ]}
      />

      <PillarTile
        label="On The Fylde Coast"
        title="Onsite Repairs."
        subtitle="We Do Business Onsite Repairs."
        photoUrl="https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=1200&q=85&auto=format&fit=crop"
        ctas={[
          { href: SITE_INFO.phone.landline.href, label: `Call ${SITE_INFO.phone.landline.display}`, variant: 'primary' },
          { href: SITE_INFO.phone.landline.href, label: 'Call To Arrange', variant: 'arrow' }
        ]}
      />

    </div>
  </section>

  <!-- MEET JOHN — humanity / trust signal -->
  <section class="feature-card-wrap">
    <div class="feature-card reversed">
      <div class="copy">
        <span class="eyebrow">Meet the engineer</span>
        <h2 class="display-2">No call centre. No junior staff. Just John.</h2>
        <p>Mac Repairs Blackpool is run by one experienced Apple technician working from a Cleveleys studio. When you call, you speak to John. When you drop a Mac in, John is the one repairing it.</p>
        <p>Component-level board repair, screen and battery work, data recovery, onsite visits. 15+ years on the Fylde Coast. 5.0 stars from 39 Google reviews.</p>
        <div class="ctas">
          <a href={SITE_INFO.phone.landline.href} class="btn btn-primary">Speak to John on {SITE_INFO.phone.landline.display}</a>
          <a href="/about/" class="arrow-link">More about the workshop</a>
        </div>
      </div>
      <div class="visual" style="background: linear-gradient(135deg, #FFE5DD 0%, #FFD4C2 50%, #FFC4A8 100%); position: relative; overflow: hidden; padding: 0; min-height: 480px;">
        <img
          src="/john.webp"
          alt="John Wellby, Apple technician at Mac Repairs Blackpool"
          style="
            width: 100%;
            height: auto;
            position: absolute;
            bottom: -8%;
            left: 50%;
            transform: translateX(-50%);
            display: block;
          "
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- OEM BAND -->
  <section class="section-light section-pad-lg" style="text-align: center; position: relative; overflow: hidden;">
    <div class="container">
      <h2 class="display-1" style="margin-bottom: 18px;">Independent Apple Specialists with OEM Parts.</h2>
      <span class="glass-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--blue);"><polyline points="20 6 9 17 4 12"/></svg>
        Experienced Apple Technician
      </span>
    </div>
  </section>

  <!-- APPLE COMPUTER SALES -->
  <section class="feature-card-wrap">
    <div class="feature-card">
      <div class="copy">
        <span class="eyebrow">Apple Computer Sales</span>
        <h2 class="display-2">New and used iMacs and MacBooks.</h2>
        <p>We sell new, used and refurbished Apple computers, spec'd up to your choice and budget.</p>
        <p>The New Macs come with 12 months Apple Care and sealed Box. We also add a 90 day warranty with our used Macs.</p>
        <p>Trade-ins are possible depending on year and condition.</p>
        <div class="ctas">
          <a href={SITE_INFO.phone.landline.href} class="btn btn-primary">Call to discuss</a>
          <a href="/contact-us/" class="arrow-link">Contact us</a>
        </div>
      </div>
      <div
        class="visual"
        style="background-image: linear-gradient(180deg, rgba(245,245,247,0) 60%, rgba(245,245,247,0.4) 100%), url('https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=1200&q=85&auto=format&fit=crop');"
      >
        <div class="glass-card">
          <div class="title">{SITE_INFO.name}</div>
          <div class="text">New Apple Computers with Full Apple Care Warranty</div>
        </div>
      </div>
    </div>
  </section>

</Base>
